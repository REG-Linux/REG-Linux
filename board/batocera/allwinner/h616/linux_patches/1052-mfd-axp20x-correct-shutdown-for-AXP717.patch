From af2144afe0735fec8e89f354c016bee20a3bb22f Mon Sep 17 00:00:00 2001
From: Ryan Walklin <ryan@testtoast.com>
Date: Tue, 28 May 2024 14:28:54 +1200
Subject: [PATCH 52/53] mfd: axp20x: correct shutdown for AXP717

The AXP717 PMIC has a different shutdown register. Correct the shutdown
process to use the right register.

Fixes: b5bfc8ab2484 ("mfd: axp20x: Add support for AXP717 PMIC")
Signed-off-by: Chris Morgan <macromorgan@hotmail.com>
---
 drivers/mfd/axp20x.c       | 9 ++++++++-
 include/linux/mfd/axp20x.h | 1 +
 2 files changed, 9 insertions(+), 1 deletion(-)

diff --git a/drivers/mfd/axp20x.c b/drivers/mfd/axp20x.c
index d52d0c1c3367..ff1ada378baf 100644
--- a/drivers/mfd/axp20x.c
+++ b/drivers/mfd/axp20x.c
@@ -29,6 +29,7 @@
 #include <linux/regulator/consumer.h>
 
 #define AXP20X_OFF	BIT(7)
+#define AXP717_OFF	BIT(0)
 
 #define AXP806_REG_ADDR_EXT_ADDR_MASTER_MODE	0
 #define AXP806_REG_ADDR_EXT_ADDR_SLAVE_MODE	BIT(4)
@@ -51,6 +52,7 @@ static const char * const axp20x_model_names[] = {
 };
 
 static const struct regmap_range axp152_writeable_ranges[] = {
+	regmap_reg_range(AXP717_OFF_CTRL, AXP717_OFF_CTRL),
 	regmap_reg_range(AXP152_LDO3456_DC1234_CTRL, AXP152_IRQ3_STATE),
 	regmap_reg_range(AXP152_DCDC_MODE, AXP152_PWM1_DUTY_CYCLE),
 };
@@ -1211,17 +1213,22 @@ static int axp20x_power_off(struct sys_off_data *data)
 {
 	struct axp20x_dev *axp20x = data->cb_data;
 	unsigned int shutdown_reg;
+	unsigned int pwoff_reg = AXP20X_OFF;
 
 	switch (axp20x->variant) {
 	case AXP313A_ID:
 		shutdown_reg = AXP313A_SHUTDOWN_CTRL;
 		break;
+	case AXP717_ID:
+		pwoff_reg = AXP717_OFF;
+		shutdown_reg = AXP717_OFF_CTRL;
+		break;
 	default:
 		shutdown_reg = AXP20X_OFF_CTRL;
 		break;
 	}
 
-	regmap_write(axp20x->regmap, shutdown_reg, AXP20X_OFF);
+	regmap_write(axp20x->regmap, shutdown_reg, pwoff_reg);
 
 	/* Give capacitors etc. time to drain to avoid kernel panic msg. */
 	mdelay(500);
diff --git a/include/linux/mfd/axp20x.h b/include/linux/mfd/axp20x.h
index 107808df33e9..395f26a72b01 100644
--- a/include/linux/mfd/axp20x.h
+++ b/include/linux/mfd/axp20x.h
@@ -123,6 +123,7 @@ enum axp20x_variants {
 #define AXP717_INPUT_CUR_LIMIT_CTRL	0x17
 #define AXP717_MODULE_EN_CONTROL_2	0x19
 #define AXP717_BOOST_CONTROL		0x1e
+#define AXP717_OFF_CTRL			0x27
 #define AXP717_IRQ0_EN			0x40
 #define AXP717_IRQ1_EN			0x41
 #define AXP717_IRQ2_EN			0x42
-- 
