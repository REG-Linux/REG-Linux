config BR2_PACKAGE_REGLINUX_SAMBA
        bool "reglinux-samba"

	select BR2_PACKAGE_SAMBA4	\
		if BR2_PACKAGE_BATOCERA_TARGET_WINE    || \
		   BR2_PACKAGE_BATOCERA_TARGET_RK3128

	select BR2_PACKAGE_KSMBD_TOOLS  \
		if (!BR2_PACKAGE_BATOCERA_TARGET_RK3128)

        help
          Samba custom implementation using either ksmbd or plain samba4
